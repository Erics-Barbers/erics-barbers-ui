  "components": {
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "Password123",
            "description": "Password must be 8-20 characters long, contain at least one letter and one number"
          }
        },
        "required": ["email", "password"]
      },
      "VerifyEmailDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Verification token sent to the user email",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          }
        },
        "required": ["token"]
      },
      "SendVerificationDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address to send the verification email to",
            "example": "user@example.com"
          }
        },
        "required": ["email"]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "password": {
            "type": "string",
            "example": "SecurePassword123",
            "description": "User password (8-20 characters)"
          }
        },
        "required": ["email", "password"]
      },
      "LogOutDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "example": "some-refresh-token",
            "description": "Refresh token for logging out"
          },
          "userId": {
            "type": "string",
            "example": "user-id-123",
            "description": "User ID associated with the refresh token"
          }
        },
        "required": ["refreshToken", "userId"]
      },
      "ResetPasswordEmailDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address to send the reset password email to",
            "example": "user@example.com"
          }
        },
        "required": ["email"]
      },
      "ResetPasswordDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "User email address"
          },
          "newPassword": {
            "type": "string",
            "example": "NewPassword123",
            "description": "New password must be 8-20 characters long, contain at least one letter and one number"
          }
        },
        "required": ["email", "newPassword"]
      },
      "MfaDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "user-id-123",
            "description": "User ID for MFA verification"
          },
          "mfaCode": {
            "type": "string",
            "example": "123456",
            "description": "MFA code for verification"
          }
        },
        "required": ["userId", "mfaCode"]
      },
      "CreateBookingDto": { "type": "object", "properties": {} },
      "UpdateBookingDto": { "type": "object", "properties": {} }
    }
  }
}
